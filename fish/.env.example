# Copy to .env.local and fill in.

# LiveKit Cloud project credentials.
# Get these from https://cloud.livekit.io → your project → Settings → Keys.
LIVEKIT_URL=wss://<your-project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Provider API keys.
# Soniox real-time multilingual STT (https://console.soniox.com → API keys).
SONIOX_API_KEY=
OPENAI_API_KEY=
FISH_API_KEY=
# Beyond Presence avatar (https://app.bey.dev → API keys).
BEY_API_KEY=

# Optional: override the LLM (OpenAI model id; default gpt-5.4-mini).
# OPENAI_MODEL=gpt-5.4-mini
# Optional: pick a specific Fish voice / Beyond Presence avatar.
# FISH_VOICE_ID=747b05c0add940baa95270cf68c0cc2e
# BEY_AVATAR_ID=b9be11b8-89fb-4227-8f86-4a881393cbdb

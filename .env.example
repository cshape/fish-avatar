# Root env for `docker compose up`. Copy to .env and fill in.
#
#   cp .env.example .env
#
# Compose injects these into both the agent and web containers. The web service
# only needs the LIVEKIT_* values (to mint room tokens); the provider keys are
# used by the agent worker. Running with `make dev` / outside Docker instead
# uses the per-service fish/.env.local and web/.env.local files (see READMEs).

# LiveKit Cloud project — both services and the browser connect to the same one.
# https://cloud.livekit.io → your project → Settings → Keys.
LIVEKIT_URL=wss://<your-project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Provider API keys (used by the agent worker).
# Soniox real-time multilingual STT (https://console.soniox.com → API keys).
SONIOX_API_KEY=
OPENAI_API_KEY=
FISH_API_KEY=
# Beyond Presence avatar (https://app.bey.dev → API keys).
BEY_API_KEY=
